# Razorpay Key ID — required for fixed ₹299 checkout modal
# Get from: dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=

# Optional: fixed-amount Payment Link (rzp.io/... or pages.razorpay.com/...)
# Do NOT use razorpay.me/@username — that lets users enter any amount
VITE_RAZORPAY_PAYMENT_LINK=

VITE_TRIAL_DAYS=3
VITE_PREMIUM_AMOUNT=29900

# Google AdSense
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_BANNER_SLOT=
